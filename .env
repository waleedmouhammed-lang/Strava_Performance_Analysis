# This is the application client id and it will be used during the authorization step.
STRAVA_CLIENT_ID=227797

# This is the application client secret and it will be used during the authorization step.
STRAVA_CLIENT_SECRET=cd285bd588b6b15d33fcef924184a24949a28e90

# This is the authorization code we obtained from the Strava API after the user authorized our application. It will be used to exchange for an access token.
STRAVA_AUTHORIZATION_CODE=6149ba7c2206664d8074c453d7335ec87ce76cbf

# This is the callback URL that Strava will redirect to after the user authorizes the application. It should match the one registered in the Strava API settings.
STRAVA_REDIRECT_URI=http://localhost

# This is the scope of permissions that the application is requesting from the user.
STRAVA_SCOPE=read,read_all, profile:read_all, activity:read_all