model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Strava Activities","DimDate","DimAthlete","DimActivityType","DimGeography","DimHRZone","FactActivities","_Measures"]

annotation PBI_ProTooling = ["DevMode","MCP-PBIModeling"]

ref table DimDate
ref table DimHRZone
ref table DimAthlete
ref table DimActivityType
ref table DimGeography
ref table FactActivities
ref table _Measures

ref cultureInfo en-US

