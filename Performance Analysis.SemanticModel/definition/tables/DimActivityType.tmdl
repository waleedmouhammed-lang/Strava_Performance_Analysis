	column is_outdoor
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 887b7219-bb87-4a19-86ce-7c11ef7b1f1e
		summarizeBy: none
		sourceColumn: is_outdoor

